# Copy this file to .env and fill with your real values.
# Example for AWS RDS PostgreSQL.

DB_URL=jdbc:postgresql://your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/postgres?sslmode=require&preferQueryMode=simple&connectTimeout=30&socketTimeout=120&tcpKeepAlive=true
DB_USERNAME=postgres
DB_PASSWORD=your_rds_db_password
JWT_SECRET=replace_with_a_long_random_secret

# Optional (AI service)
GROQ_API_KEY=your_groq_api_key

# Optional (Weather integration)
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org
