# Copy this file to .env and fill with your real values.
# For Supabase pooled connection, keep port 6543 and username format postgres.<project-ref>.

DB_URL=jdbc:postgresql://aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&preferQueryMode=simple
DB_USERNAME=postgres.your_project_ref
DB_PASSWORD=your_supabase_db_password
JWT_SECRET=replace_with_a_long_random_secret

# Optional (AI service)
GROQ_API_KEY=your_groq_api_key

# Optional (Weather integration)
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org
